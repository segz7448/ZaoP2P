{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../ui",
    "distDir": "../ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Zao P2P",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": { "open": true, "save": true },
      "fs": { "all": true, "scope": ["$APPDATA/*", "$APPDATA/**"] }
    },
    "bundle": {
      "active": true,
      "identifier": "com.zao.p2p.windows",
      "targets": ["msi", "nsis"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Zao P2P",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
